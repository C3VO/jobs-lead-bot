TG_BOT_TOKEN=replace_me
TG_CHAT_ID=replace_me

# Reddit search
SUBREDDITS=forhire,freelance_forhire,jobbit
KEYWORDS=javascript,node,react,next,wordpress,opencart,shopify,frontend,fullstack
LIMIT_PER_SUB=50
INTERVAL_MINUTES=10
REQUEST_DELAY_MS=500
MAX_REQUESTS_PER_RUN=300
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_CLIENT_ID=your_app_client_id
REDDIT_CLIENT_SECRET=your_app_client_secret
REDDIT_USER_AGENT=script:reddit-jobs-telegram-bot:1.0 (by /u/your_reddit_username)

# Translation
TRANSLATE_ENABLED=true
LIBRETRANSLATE_URL=http://localhost:5001/translate
LIBRETRANSLATE_API_KEY=
LIBRETRANSLATE_FROM=en
LIBRETRANSLATE_TO=ru

# Misc
DRY_RUN=false
RUN_ONCE=false
REPORT_ONLY=false
REPORT_HOURS=24
REPORT_SEND=true
